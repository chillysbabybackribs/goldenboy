{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "declaration": false
  },
  "include": ["src/renderer/**/*", "src/shared/**/*"],
  "exclude": ["src/**/*.test.ts"]
}
