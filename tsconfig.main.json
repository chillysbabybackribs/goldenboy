  "compilerOptions": {
    "outDir": "dist/main",
    "rootDir": "src",
    "allowJs": true
  },
  "include": ["src/main/**/*", "src/shared/**/*"],
  "exclude": [
    "src/main/**/*.test.ts",
    "src/main/models/**/*",
    "src/main/research/**/*",
    "src/shared/**/*.test.ts"
  ]
}
