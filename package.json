{
  "name": "v2-workspace",
  "version": "1.0.0",
  "description": "V2 Workspace browser build",
  "main": "dist/main/main/main.js",
  "scripts": {
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:renderer": "tsc -p tsconfig.renderer.json",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer && npm run copy:html",
    "copy:html": "node scripts/copy-renderer.js",
    "start": "npm run build && electron .",
    "dev": "npm run build && electron .",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "electron": "^41.2.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "node-pty": "^1.1.0"
  }
}
